# ============================================================
#  Evolver — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
.venv/
venv/
env/
ENV/
# NB: .python-version viene committato — pinna la Python per uv/pyenv

# --- uv ---
# uv.lock viene committato (è il lockfile riproducibile)

# --- Testing & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- Type checkers ---
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Node / Next.js ---
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
.pnpm-store/
.npm/
.yarn/

# --- Environment & secrets ---
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
secrets/
.anthropic/

# --- Database & data ---
*.db
*.sqlite
*.sqlite3
data/
backfill_cache/
*.parquet
*.feather
pgdata/
redis-data/
postgres-data/

# --- ML / GA artifacts ---
outputs/
runs/
checkpoints/
*.pkl
*.joblib
*.h5
*.onnx
mlruns/
wandb/

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
*.lnk
$RECYCLE.BIN/

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.claude/
.vimrc.local

# --- Docker ---
.docker/

# --- Git restructure backups ---
.git.backup*
*.git.backup-*

# --- Misc ---
*.bak
*.tmp
.cache/
