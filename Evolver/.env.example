# =============================================================================
#  Evolver — variabili d'ambiente
# =============================================================================
#  Copia questo file in `.env` e personalizza.
#  Non committare mai il `.env` (è già in .gitignore).
# =============================================================================

# --- Environment ---
ENV=dev
DEBUG=true
LOG_LEVEL=INFO

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Database (Postgres + TimescaleDB) ---
POSTGRES_USER=evolver
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=evolver
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://evolver:changeme_in_prod@localhost:5432/evolver
DATABASE_URL_SYNC=postgresql+psycopg://evolver:changeme_in_prod@localhost:5432/evolver
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Anthropic ---
# Crea su https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_OPUS=claude-opus-4-6
CLAUDE_MAX_RETRIES=3
CLAUDE_TIMEOUT_S=60

# --- Binance (opzionale per dati pubblici, obbligatorie per trading) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_USE_TESTNET=false

# --- Trading universe ---
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAMES=15m,1h,4h,1d

# --- Paper trading ---
PAPER_INITIAL_BALANCE_USDT=10000.0
PAPER_FEE_MAKER=0.001
PAPER_FEE_TAKER=0.001
PAPER_SLIPPAGE_BPS=2.0

# --- News (CryptoPanic) ---
# Crea su https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=
NEWS_POLL_INTERVAL_S=300

# --- Backend container port (per docker-compose) ---
BACKEND_PORT=8000
